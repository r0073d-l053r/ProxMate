{
  // ProxMate IDE — machine defaults baked into the code-server image.
  // Base theme supplies syntax highlighting; the colorCustomizations below
  // repaint the whole VS Code shell in ProxMate's brand palette so the editor
  // reads as part of the same product. Palette mirrors the app's dark theme
  // (frontend/src/app/globals.css), converted from OKLCH to hex:
  //   bg  #0d1013  chrome #111418  panel #15191c  hover #23272b  sel #292e34
  //   text #f3f5f8  muted #95a0ab   accent #3186e9  accent-hover #4ba3f7
  //   border #ffffff17  danger #ff6467
  "workbench.colorTheme": "Default Dark Modern",
  "workbench.startupEditor": "none",
  "telemetry.telemetryLevel": "off",
  "security.workspace.trust.enabled": false,
  "update.mode": "none",
  "terminal.integrated.defaultProfile.linux": "bash",
  "extensions.autoCheckUpdates": false,
  "window.menuBarVisibility": "compact",
  // OpenCode is the focus agent — keep VS Code's built-in "Build with Agent" chat
  // (the right/secondary sidebar) out of the way so it never pops up on open.
  "workbench.secondarySideBar.defaultVisibility": "hidden",
  "chat.commandCenter.enabled": false,
  "editor.fontFamily": "'Geist Mono', 'Cascadia Code', Menlo, Monaco, 'Courier New', monospace",
  "workbench.colorCustomizations": {
    "focusBorder": "#3186e9",
    "foreground": "#f3f5f8",
    "descriptionForeground": "#95a0ab",
    "disabledForeground": "#95a0ab",
    "selection.background": "#3186e966",
    "widget.border": "#ffffff17",
    "icon.foreground": "#95a0ab",
    "sash.hoverBorder": "#3186e9",

    "titleBar.activeBackground": "#111418",
    "titleBar.activeForeground": "#f3f5f8",
    "titleBar.inactiveBackground": "#111418",
    "titleBar.inactiveForeground": "#95a0ab",
    "titleBar.border": "#ffffff17",

    "activityBar.background": "#111418",
    "activityBar.foreground": "#f3f5f8",
    "activityBar.inactiveForeground": "#95a0ab",
    "activityBar.activeBorder": "#3186e9",
    "activityBar.border": "#ffffff17",
    "activityBarBadge.background": "#3186e9",
    "activityBarBadge.foreground": "#ffffff",

    "sideBar.background": "#111418",
