# ─── ProxMate Docker Compose configuration ────────────────────
# Copy to ".env" in this directory before running `docker compose up -d`.

# REQUIRED. Encrypts Proxmox token + JWT secret at rest. Generate once and keep
# it stable — if it changes, previously stored secrets can't be decrypted.
#   openssl rand -hex 32
ENCRYPTION_KEY=

# Public origin of the frontend (used for the backend CORS allow-list).
FRONTEND_URL=http://localhost:3000

# API base URL the browser will call. Baked into the frontend at build time.
# For a real deployment, set this to your public API URL, e.g.
#   https://proxmate.example.com/api
NEXT_PUBLIC_API_URL=http://localhost:4000/api

# Host ports to publish (optional).
BACKEND_PORT=4000
FRONTEND_PORT=3000
