# ─── ProxMate Docker Compose configuration ────────────────────
# Copy to ".env" in this directory before running `docker compose up -d`.
#
# Two example profiles are shown below. Use the LOCAL block for a quick spin-up,
# or the PRODUCTION block (single HTTPS domain behind a reverse proxy) for a real
# deployment — passkeys, Secure cookies, and SSO all require HTTPS.

# REQUIRED. Encrypts the Proxmox token + JWT secret + SSO/SMTP secrets at rest.
# Generate once and keep it STABLE — if it changes, stored secrets can't be
# decrypted (you'd have to re-enter the Proxmox token, SSO secret, etc.).
#   openssl rand -hex 32
ENCRYPTION_KEY=

# ─── LOCAL (HTTP, two ports) ──────────────────────────────────
# Uncomment for a quick local run. Passkeys/SSO won't work over plain HTTP
# except on "localhost".
# FRONTEND_URL=http://localhost:3000
# NEXT_PUBLIC_API_URL=http://localhost:4000/api
# BACKEND_PUBLIC_URL=http://localhost:4000
# COOKIE_SECURE=false
# TRUST_PROXY=0
# BIND_ADDR=0.0.0.0

# ─── PRODUCTION (one HTTPS domain behind a reverse proxy) ──────
# Replace proxmate.example.com with your domain. The reverse proxy terminates
# TLS and routes "/api" → backend:4000 and everything else → frontend:3000.
FRONTEND_URL=https://proxmate.example.com
NEXT_PUBLIC_API_URL=https://proxmate.example.com/api
BACKEND_PUBLIC_URL=https://proxmate.example.com
WEBAUTHN_RP_ID=proxmate.example.com
WEBAUTHN_ORIGIN=https://proxmate.example.com
COOKIE_SECURE=true
TRUST_PROXY=1
# Only expose the app ports to the local reverse proxy, not the whole network.
BIND_ADDR=127.0.0.1

# Host ports the containers listen on (the reverse proxy targets these).
BACKEND_PORT=4000
FRONTEND_PORT=3000

# Optional: tune the auth rate limiter (defaults: 20 requests / 15 min / IP).
# AUTH_RATE_LIMIT_MAX=20
# AUTH_RATE_LIMIT_WINDOW_MS=900000
