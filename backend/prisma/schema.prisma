generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  passwordHash  String
  displayName   String
  role          String    @default("user") // "admin" | "user"

  // SSO (OIDC) link — the provider's stable `sub` claim, set on first SSO login.
  ssoSubject    String?   @unique

  // Two-factor auth (TOTP). `twoFactorSecret` is the AES-encrypted base32 secret.
  twoFactorEnabled Boolean  @default(false)
  twoFactorSecret  String?
  // Admin-enforced (via the invite): user must set up a 2FA method before using ProxMate.
  require2fa       Boolean  @default(false)

  // Brute-force lockout: consecutive failed-password count + a temporary lock
  // window. Reset on any successful password verification; auto-expires.
  failedLoginAttempts Int       @default(0)
  lockedUntil         DateTime?

  // Resource Quotas (set from invite token at registration)
  maxCpu        Int       @default(0)      // total vCPU cores allowed
  maxRam        Int       @default(0)      // total RAM in MB
  maxStorage    Int       @default(0)      // total disk in GB

  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  vms            VirtualMachine[]
  invitesCreated InviteToken[]  @relation("CreatedInvites")
  usedInvite     InviteToken?   @relation("UsedInvite")
  sessions       Session[]
  sshKeys        SshKey[]
}

// A reusable SSH public key saved to a user's profile, so cloud-init deploys can
// pick from a dropdown instead of pasting the key every time (DigitalOcean-style).
model SshKey {
  id         String    @id @default(cuid())
  userId     String
  name       String                    // user-friendly label, e.g. "laptop"
  publicKey  String                    // the OpenSSH public key line
  createdAt  DateTime  @default(now())
  lastUsedAt DateTime?

  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model Session {
  id          String   @id @default(cuid())
  userId      String
  token       String   @unique
  csrfToken   String?                  // double-submit CSRF token bound to this session
  expiresAt   DateTime
  createdAt   DateTime @default(now())

  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([token])
  @@index([userId])
}

model InviteToken {
  id          String    @id @default(cuid())
  token       String    @unique
  createdById String
  label       String?

  maxCpu      Int
  maxRam      Int
  maxStorage  Int
  require2fa  Boolean   @default(false) // force the invited user to set up 2FA

  usedById    String?   @unique
  expiresAt   DateTime
  createdAt   DateTime  @default(now())

  createdBy   User      @relation("CreatedInvites", fields: [createdById], references: [id])
  usedBy      User?     @relation("UsedInvite", fields: [usedById], references: [id])

  @@index([token])
}

model VirtualMachine {
  id            String    @id @default(cuid())
  userId        String
  proxmoxVmId   Int
  proxmoxNode   String
  name          String
  description   String?

  cpu           Int
  ram           Int
  storage       Int
  os            String

  status        String    @default("creating") // creating | running | stopped | error
  ipAddress     String?

  // Optional user labels for grouping/filtering (lowercase, comma-separated).
  tags          String?

  // Optional power schedule (5-field cron, server timezone). Null = no auto action.
  startCron     String?   // auto-start when this fires
  stopCron      String?   // auto-shutdown (graceful) when this fires

  // Optional per-VM backup policy. backupCron null = fall back to the cluster-wide
  // weekly default; set = this VM is backed up on its own schedule instead.
  // backupKeep null = default rolling retention (MATESTATE_RETENTION).
  backupCron    String?   // 5-field cron; when set, a MateState is taken as it fires
  backupKeep    Int?      // how many MateStates to keep for this VM

  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  user          User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  matestates    MateState[]

  @@index([userId])
  @@index([proxmoxVmId])
}

// A point-in-time backup of a VM (Proxmox vzdump). "MateState" — never "droplet".
// Strict rolling retention: only the 2 most recent per VM are kept; older are pruned.
model MateState {
  id            String    @id @default(cuid())
  vmId          String                              // FK to VirtualMachine.id
  proxmoxVmId   Int                                 // the VMID the backup was taken of
  proxmoxNode   String                              // where the backup currently lives
  storage       String                              // Proxmox storage holding the backup
  volid         String    @unique                   // e.g. local:backup/vzdump-qemu-100-…
  size          Int       @default(0)               // bytes
  status        String    @default("creating")      // creating | ready | restoring | error
  kind          String    @default("scheduled")     // scheduled | manual
  notes         String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  vm            VirtualMachine @relation(fields: [vmId], references: [id], onDelete: Cascade)

  @@index([vmId])
}

model SystemConfig {
  key         String    @id
  value       String
  sensitive   Boolean   @default(false)
  updatedAt   DateTime  @updatedAt
}

// Append-only record of who did what, for trust/debugging/accountability on a
// multi-tenant box. Deliberately NOT relationally tied to User: actorEmail is
// denormalized so the trail survives a user (and their cascade) being deleted.
model AuditLog {
  id          String    @id @default(cuid())
  userId      String?                       // acting user id (null for anonymous / failed login)
  actorEmail  String?                       // denormalized actor email (outlives the user row)
  action      String                        // e.g. "vm.create", "vm.delete", "auth.login"
  targetType  String?                       // e.g. "vm", "matestate", "session"
  targetId    String?                       // id/name of the affected entity
  detail      String?                       // short human-readable summary
  ip          String?                       // client IP (honors trust proxy)
  createdAt   DateTime  @default(now())

  @@index([createdAt])
  @@index([userId])
}

// A published, cloneable OS build (maps to a Proxmox template VM).
model Template {
  id            String    @id @default(cuid())
  name          String
  description   String?
  os            String?                       // display label, e.g. "Debian 12"
  arch          String?                       // guest CPU arch: "amd64" | "arm64" (null = legacy/unknown)
  proxmoxVmId   Int                           // the Proxmox template's VMID
  proxmoxNode   String                        // node the template lives on
  diskGb        Int       @default(0)         // base disk size = minimum deployable disk
  notes         String?                       // admin notes shown to users (e.g. default login creds)
  cloudInit     Boolean   @default(false)      // true = cloud image; deploy injects SSH key/user (no ISO installer)
  icon          String?                       // custom icon data-URI (admin upload); null = auto OS icon
  published     Boolean   @default(true)

  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@unique([proxmoxVmId])
}

// Email-based password reset: the raw token is emailed; only its SHA-256 hash is
// stored. Single-use (usedAt) and short-lived (expiresAt).
model PasswordResetToken {
  id        String    @id @default(cuid())
  userId    String
  tokenHash String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  @@index([userId])
}

// "Contact admin for a password reset" fallback when no SMTP is configured —
// surfaced to admins, who set a temp password or issue a reset link.
model PasswordResetRequest {
  id         String    @id @default(cuid())
  userId     String
  email      String                      // denormalized for the admin list
  status     String    @default("pending") // pending | handled
  createdAt  DateTime  @default(now())
  handledAt  DateTime?

  @@index([status])
}

// One-time TOTP recovery codes (lost-device backup). Stored as SHA-256 hashes.
model TwoFactorRecoveryCode {
  id        String    @id @default(cuid())
  userId    String
  codeHash  String
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  @@index([userId])
}

// WebAuthn passkeys. `id` is the credential ID (base64url); `publicKey` is the
// COSE public-key blob. `counter` guards against cloned-authenticator replay.
model Passkey {
  id         String    @id
  userId     String
  publicKey  Bytes
  counter    Int       @default(0)
  transports String?                   // CSV of authenticator transports
  name       String                    // user-friendly label
  deviceType String?                   // "singleDevice" | "multiDevice"
  backedUp   Boolean   @default(false)
  createdAt  DateTime  @default(now())
  lastUsedAt DateTime?

  @@index([userId])
}
