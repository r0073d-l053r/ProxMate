# ─── ProxMate Backend Environment ─────────────────────────────
# Server
PORT=4000
NODE_ENV=development
FRONTEND_URL=http://localhost:3000

# Database (SQLite file path relative to backend/)
DATABASE_URL="file:./proxmate.db"

# Encryption key for sensitive SystemConfig values
# Auto-generated during first-time setup — do NOT change after setup
ENCRYPTION_KEY=

# ─── Observability (optional) ─────────────────────────────────
# LOG_LEVEL=info            # pino level: trace|debug|info|warn|error (default: debug in dev)
# METRICS_TOKEN=            # if set, GET /metrics requires `Authorization: Bearer <token>`

# ─── Proxmox client (optional) ────────────────────────────────
# PROXMOX_TIMEOUT_MS=15000  # per-request timeout
# PROXMOX_RETRIES=2         # retries for transient failures on idempotent reads only

# ─── Rate limiting (optional) ─────────────────────────────────
# API_WRITE_RATE_LIMIT_MAX=60          # mutating requests per window per IP
# API_WRITE_RATE_LIMIT_WINDOW_MS=60000

# ─── PostgreSQL (optional, for HA / larger deployments) ───────
# To run on Postgres instead of SQLite: set the Prisma datasource provider to
# "postgresql" in backend/prisma/schema.prisma and point DATABASE_URL at it:
# DATABASE_URL="postgresql://proxmate:secret@db:5432/proxmate?schema=public"
