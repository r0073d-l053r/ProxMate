# ─── ProxMate Backend Environment ─────────────────────────────
# Server
PORT=4000
NODE_ENV=development
FRONTEND_URL=http://localhost:3000

# Database (SQLite file path relative to backend/)
DATABASE_URL="file:./proxmate.db"

# Encryption key for sensitive SystemConfig values. MUST be 64 hex chars
# (32 bytes) — e.g. `openssl rand -hex 32`. Auto-generated during first-time
# setup; do NOT change after setup (stored secrets couldn't be decrypted).
ENCRYPTION_KEY=

# ─── Server binding (optional) ────────────────────────────────
# BIND_ADDR=0.0.0.0         # interface the API process listens on. Default 0.0.0.0
#                           # (required inside Docker so the proxy/frontend can reach
#                           # it). On bare metal behind a same-host proxy, set
#                           # 127.0.0.1 to listen on loopback only.

# ─── Observability (optional) ─────────────────────────────────
# LOG_LEVEL=info            # pino level: trace|debug|info|warn|error (default: debug in dev)
# METRICS_TOKEN=            # /metrics requires `Authorization: Bearer <token>` when set.
#                           # In PRODUCTION, /metrics returns 404 unless this is set
#                           # (scrape only over localhost, or set a token).

# ─── Outbound URL safety / SSRF (optional) ────────────────────
# Admin-configured webhooks + cloud-image URLs are blocked from targeting
# private/loopback/metadata addresses. Homelab installs that legitimately point
# at a LAN service (self-hosted Mattermost/ntfy, a local image mirror) can opt in:
# ALLOW_PRIVATE_OUTBOUND_URLS=true   # default false; scheme + no-credentials always enforced

# ─── Proxmox client (optional) ────────────────────────────────
# PROXMOX_TIMEOUT_MS=15000  # per-request timeout
# PROXMOX_RETRIES=2         # retries for transient failures on idempotent reads only

# ─── Rate limiting (optional) ─────────────────────────────────
# API_WRITE_RATE_LIMIT_MAX=60          # mutating requests per window per IP
# API_WRITE_RATE_LIMIT_WINDOW_MS=60000
# PUBLIC_TOKEN_RATE_LIMIT_MAX=60       # public token GETs (invite lookup, downloads) per window per IP
# PUBLIC_TOKEN_RATE_LIMIT_WINDOW_MS=900000

# ─── PostgreSQL (optional, for HA / larger deployments) ───────
# To run on Postgres instead of SQLite: set the Prisma datasource provider to
# "postgresql" in backend/prisma/schema.prisma and point DATABASE_URL at it:
# DATABASE_URL="postgresql://proxmate:secret@db:5432/proxmate?schema=public"
